# Copy to .env and adjust. All LLAMA_ARG_* variables are native llama-server
# settings: every CLI flag has an env equivalent (see llama-server --help).

# llama.cpp release tag baked into the image (docker build arg)
LLAMA_CPP_VERSION=b9993

# Model to download from Hugging Face: <user>/<repo>[:<quant>]
# Downloaded once into the llama-models volume, reused on restarts.
LLAMA_ARG_HF_REPO=ggml-org/gemma-3-4b-it-GGUF:Q4_K_M

# HTTP API port
LLAMA_ARG_PORT=8080

# Context size (tokens)
LLAMA_ARG_CTX_SIZE=8192

# Layers offloaded to the GPU (999 = all; set 0 to force CPU)
LLAMA_ARG_N_GPU_LAYERS=999

# Hugging Face token, only needed for gated/private repos
#HF_TOKEN=

# Extra raw llama-server CLI arguments, e.g. "--threads 8 --flash-attn"
#LLAMA_EXTRA_ARGS=
